    "#lossfn\n",
    "bce = nn.BCELoss()\n",
    "def dice_loss(pred, target):\n",
    "    smooth = 1e-6\n",
    "    pred = pred.view(-1)\n",
    "    target = target.view(-1)\n",
    "    intersec = (pred*target).sum()\n",
    "    return 1 - ((2*intersec+smooth)/(pred.sum() + target.sum() + smooth))"
   ]
